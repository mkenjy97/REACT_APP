rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Function to check if user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Function to fetch user role from their profile document
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper roles
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'Admin';
    }

    function isManager() {
      return isAuthenticated() && (getUserRole() == 'Manager' || getUserRole() == 'Admin');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Users can read all profiles (needed for the users page)
    // 2. Users can write their own profiles, Admins can write all
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // 3. Global settings collection
    // Read: Anyone (needed for pre-login theme)
    // Write: Managers and Admins
    match /globalSettings/{settingId} {
      allow read: if true;
      allow write: if isManager();
    }
    
    // 4. Places collection for Maps
    // Read: Anyone (or isAuthenticated)
    match /places/{placeId} {
      allow read: if true;
      allow write: if isManager();
    }

    // 5. Chats and Messages
    match /chats/{chatId} {
      allow read, write: if isAuthenticated();
    }
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if isAuthenticated();
    }
    
    // Example Application Data
    match /appData/{dataId} {
      allow read: if isAuthenticated();
      allow write: if isManager(); // Managers and Admins can write
    }

  }
}